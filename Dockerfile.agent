# Multica agent images: shared base + per-CLI targets.
#
#   make build-all
#   make build-claude IMAGE=ghcr.io/org/multica-agent TAG=v1.0.0
#
# Or: docker build -f Dockerfile.agent --target <claude|cursor|opencode|codex|kimi|agy> -t <image> .

ARG MULTICA_IMAGE=ghcr.io/multica-ai/multica-backend
ARG MULTICA_TAG=latest
ARG AGENT_BASE_IMAGE=base
FROM ${MULTICA_IMAGE}:${MULTICA_TAG} AS multica

# ---------------------------------------------------------------------------
# base — multica CLI, Podman, nvm, pnpm, Playwright, entrypoint (no agent CLI)
# ---------------------------------------------------------------------------
FROM debian:stable-slim AS base

# nvm requires bash; default /bin/sh is dash (https://github.com/nvm-sh/nvm#installing-in-docker)
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

WORKDIR /app

COPY --from=multica /app/multica /app/multica

ARG USER_UID=1000
ARG USER_GID=1000
ARG USERNAME=agent
ARG GIT_USER_NAME=Multica Agent
ARG GIT_USER_EMAIL=agent@example.com

RUN groupadd --gid ${USER_GID} ${USERNAME} \
 && useradd --uid ${USER_UID} --gid ${USER_GID} --create-home --shell /bin/bash ${USERNAME}

# gcc + libc6-dev provide the C toolchain cgo needs. `go test -race` (and any
# other CGO_ENABLED=1 build) links against the C runtime, so without these the
# race detector fails to compile. They are listed explicitly because the apt
# install runs with --no-install-recommends (gcc only Recommends libc6-dev,
# so it would never be pulled in automatically here).
#
# Headless-browser system deps (Playwright): Chromium, Firefox, and WebKit all
# need X11/NSS/ATK/Pango/GBM/etc. libraries to launch in a headless container.
# Pre-installing them here means agents running webapp E2E tests skip the
# `playwright install-deps` step (which runs apt-get internally and is one of
# the slowest parts of test setup). fonts-liberation + fonts-noto-color-emoji
# avoid tofu/inconsistent rendering in screenshot-based tests.
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates \
      tzdata \
      bash \
      curl \
      git \
      git-flow \
      openssh-client \
      jq ripgrep \
      unzip \
      python3 \
      gcc \
      libc6-dev \
      podman \
      passt \
      aardvark-dns \
      netavark \
      fuse-overlayfs \
      slirp4netns \
      uidmap \
      libnss3 libnspr4 \
      libatk1.0-0 libatk-bridge2.0-0 \
      libcups2 libdrm2 \
      libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
      libgbm1 libpango-1.0-0 libcairo2 \
      libasound2 libatspi2.0-0 libxshmfence1 \
      libgtk-3-0 libgdk-pixbuf-2.0-0 \
      libglib2.0-0 libxml2 libxslt1.1 \
      libjpeg62-turbo libpng16-16 libwebpdemux2 \
      libhyphen0 libenchant-2-2 libsecret-1-0 \
      libgles2 libevdev2 libdbus-glib-1-2 \
      fonts-liberation fonts-noto-color-emoji fonts-freefont-ttf \
  && rm -rf /var/lib/apt/lists/* \
  && touch /etc/subuid /etc/subgid \
  && sed -i "/^${USERNAME}:/d" /etc/subuid 2>/dev/null || true \
  && sed -i "/^${USERNAME}:/d" /etc/subgid 2>/dev/null || true \
  && echo "${USERNAME}:100000:65536" >> /etc/subuid \
  && echo "${USERNAME}:100000:65536" >> /etc/subgid \
  && ln -sf /usr/bin/podman /usr/local/bin/docker \
  && mkdir -p /home/${USERNAME}/.config/containers \
  && printf '[network]\nfirewall_driver = "none"\nnetwork_cmd_path = "/usr/bin/pasta"\n\n[engine]\nhelper_binaries_dir = ["/usr/libexec/podman", "/usr/lib/podman", "/usr/bin", "/home/%s/.local/bin"]\n' "${USERNAME}" > /home/${USERNAME}/.config/containers/containers.conf \
  && chown -R ${USER_UID}:${USER_GID} /home/${USERNAME}/.config

RUN mkdir -p /workspaces && chown ${USER_UID}:${USER_GID} /workspaces

USER ${USERNAME}
ARG NVM_VERSION=master
ARG NODE_VERSION=node
ENV NVM_DIR=/home/${USERNAME}/.nvm
ENV BASH_ENV=/home/${USERNAME}/.bash_env
RUN touch "${BASH_ENV}" \
 && echo '. "${NVM_DIR}/nvm.sh"' >> "${BASH_ENV}" \
 && echo '. "${BASH_ENV}"' >> ~/.bashrc
RUN if [ "${NVM_VERSION}" = "master" ]; then \
      install_url="https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh"; \
    else \
      install_url="https://raw.githubusercontent.com/nvm-sh/nvm/v${NVM_VERSION#v}/install.sh"; \
    fi; \
    curl -o- "${install_url}" | PROFILE="${BASH_ENV}" bash
RUN . "${NVM_DIR}/nvm.sh" \
 && nvm install "${NODE_VERSION}" \
 && nvm alias default "${NODE_VERSION}" \
 && NODE_BIN_DIR="$(dirname "$(nvm which default)")" \
 && echo "export PATH=\"${NODE_BIN_DIR}:\${PATH}\"" >> "${BASH_ENV}" \
 && mkdir -p "${HOME}/.local" \
 && ln -sfn "${NODE_BIN_DIR}" "${HOME}/.local/node-active"

ENV PNPM_HOME=/home/${USERNAME}/.local/share/pnpm
RUN mkdir -p "${PNPM_HOME}" \
 && curl -fsSL https://get.pnpm.io/install.sh | PNPM_HOME="${PNPM_HOME}" ENV="$HOME/.bashrc" SHELL="$(which bash)" bash - \
 && "${PNPM_HOME}/pnpm" --version
RUN echo "export PNPM_HOME=\"${PNPM_HOME}\"" >> "${BASH_ENV}"

# @playwright/test — provides the Playwright API/CLI for agents without the ~170MB+ browser binaries.
# Browser binaries are NOT installed here; agents run `npx playwright install <browser>` at runtime.
RUN npm install -g @playwright/test

# Headless-browser system deps (Playwright): Chromium, Firefox, and WebKit all
# need X11/NSS/ATK/Pango/GBM/etc. libraries to launch in a headless container.
# Pre-installing them here means agents running webapp E2E tests skip the
# `playwright install-deps` step (which runs apt-get internally and is one of
# the slowest parts of test setup). fonts-liberation + fonts-noto-color-emoji
# avoid tofu/inconsistent rendering in screenshot-based tests.
#
# Note: Playwright browser binaries are NOT pre-installed in the base image.
# Agents should run `npx playwright install chromium` (or firefox/webkit) at
# runtime when needed. This avoids CI hangs during image build while still
# providing the system libraries browsers depend on.

ARG GO_VERSION=1.26.5
RUN GO_ARCH="$(uname -m)" \
 && case "${GO_ARCH}" in \
      x86_64)  GO_ARCH="amd64" ;; \
      aarch64) GO_ARCH="arm64" ;; \
      *) echo "Unsupported architecture: ${GO_ARCH}" && exit 1 ;; \
    esac \
 && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${GO_ARCH}.tar.gz" -o /tmp/go.tar.gz \
 && mkdir -p "${HOME}/.local/go" \
 && tar -C "${HOME}/.local/go" --strip-components=1 -xzf /tmp/go.tar.gz \
 && rm /tmp/go.tar.gz \
 && "${HOME}/.local/go/bin/go" version

# golangci-lint — Go static-analysis aggregator, available to agents working on Go code.
# Pin the version and verify the install script's SHA256 (rtk/uv pattern); the script
# itself then downloads the matching release binary and checks its checksum internally.
# Installs into $HOME/.local/bin, already on PATH (see ENV PATH below).
ARG GOLANGCI_LINT_VERSION=v2.12.2
ARG GOLANGCI_LINT_INSTALL_SHA256=d32d3534af96cfd59546a084d22b213e8a47541cada5013aa8a84c4fa2589905
RUN mkdir -p "$HOME/.local/bin" \
 && curl -fsSL "https://raw.githubusercontent.com/golangci/golangci-lint/${GOLANGCI_LINT_VERSION}/install.sh" -o /tmp/golangci-lint-install.sh \
 && echo "${GOLANGCI_LINT_INSTALL_SHA256}  /tmp/golangci-lint-install.sh" | sha256sum -c - \
 && sh /tmp/golangci-lint-install.sh -b "$HOME/.local/bin" "${GOLANGCI_LINT_VERSION}" \
 && rm /tmp/golangci-lint-install.sh \
 && "$HOME/.local/bin/golangci-lint" version

ARG RTK_VERSION=v0.43.0
ARG RTK_INSTALL_SHA256=d6eb73a772903e13ff34ee1be8a8b24e896ba9a978f20d2279a08b4083ea6f77
RUN curl -fsSL "https://raw.githubusercontent.com/rtk-ai/rtk/refs/tags/${RTK_VERSION}/install.sh" -o /tmp/rtk-install.sh \
 && echo "${RTK_INSTALL_SHA256}  /tmp/rtk-install.sh" | sha256sum -c - \
 && RTK_VERSION="${RTK_VERSION}" sh /tmp/rtk-install.sh \
 && rm /tmp/rtk-install.sh \
 && RTK_BIN="$(PATH="$HOME/.local/bin:$PATH" command -v rtk)" && [ -x "${RTK_BIN}" ] && ln -sf "${RTK_BIN}" "$HOME/.local/bin/rk"

# uv — modern Python package/project manager; used for `uv tool install` (CLI venvs).
# Install as the agent user into $HOME/.local/bin (the same dir rtk uses), so the
# binary lands on the default PATH (see ENV PATH below). Installing to /usr/local
# would require running as root and the install script's flat layout would put
# the binary at /usr/local/uv (not on the default PATH) — $HOME/.local/bin/uv is
# simpler and matches the rtk install pattern.
ARG UV_VERSION=0.11.29
ARG UV_INSTALL_SHA256=504a79fd2ed0dcd47e7f04f0792cfd0871f62e24a7fe40fa8ae0f563a369f2bd
RUN mkdir -p "$HOME/.local/bin" \
 && curl -fsSL "https://astral.sh/uv/${UV_VERSION}/install.sh" -o /tmp/uv-install.sh \
 && echo "${UV_INSTALL_SHA256}  /tmp/uv-install.sh" | sha256sum -c - \
 && UV_INSTALL_DIR="$HOME/.local" sh /tmp/uv-install.sh \
 && rm /tmp/uv-install.sh \
 && UV_BIN="$(PATH="$HOME/.local/bin:$PATH" command -v uv || command -v "$HOME/.local/uv")" \
 && [ -x "${UV_BIN}" ] && ln -sf "${UV_BIN}" "$HOME/.local/bin/uv" \
 && "${UV_BIN}" --version

# glab — GitLab CLI, so agents can interact with GitLab (MRs, issues, CI, etc.) from the command line.
# Downloads the prebuilt binary tarball from the official release assets and verifies its SHA256
# against the published checksums. Installs into $HOME/.local/bin (already on PATH via ENV PATH below).
ARG GLAB_VERSION=1.108.0
RUN GLAB_ARCH="$(uname -m)" \
 && case "${GLAB_ARCH}" in \
      x86_64)  GLAB_ARCH="amd64"; GLAB_SHA256="cb3eb9d6b05eedef24a028b52354f12fb9a07ecfa0b5581eb161176585bc8213" ;; \
      aarch64) GLAB_ARCH="arm64"; GLAB_SHA256="681031c6477dc7eb53b07a4641e2defc6795cf7ffb18ddc6cf8bdbc1211ed782" ;; \
      *) echo "Unsupported architecture: ${GLAB_ARCH}" && exit 1 ;; \
    esac \
 && curl -fsSL "https://gitlab.com/gitlab-org/cli/-/releases/v${GLAB_VERSION}/downloads/glab_${GLAB_VERSION}_linux_${GLAB_ARCH}.tar.gz" -o /tmp/glab.tar.gz \
 && echo "${GLAB_SHA256}  /tmp/glab.tar.gz" | sha256sum -c - \
 && tar -xzf /tmp/glab.tar.gz -C /tmp bin/glab \
 && mv /tmp/bin/glab "$HOME/.local/bin/glab" \
 && chmod +x "$HOME/.local/bin/glab" \
 && rm -rf /tmp/glab.tar.gz /tmp/bin \
 && "$HOME/.local/bin/glab" version

# DuckDB — in-process SQL OLAP database CLI; useful for querying CSV/Parquet/SQLite/Postgres
# and other data sources from the command line. Prebuilt binary from official GitHub releases.
ARG DUCKDB_VERSION=v1.5.4
RUN DUCKDB_ARCH="$(uname -m)" \
 && case "${DUCKDB_ARCH}" in \
      x86_64)  DUCKDB_ARCH="amd64"; DUCKDB_SHA256="c1d6db2294895c97849bee574b21eb462528857ccf8a23617dd3e0a05dd4b770" ;; \
      aarch64) DUCKDB_ARCH="arm64"; DUCKDB_SHA256="32fea57520b1ae6caa291717d5f5d4d478fb6f8ed2d2c7054096a038fc6be833" ;; \
      *) echo "Unsupported architecture: ${DUCKDB_ARCH}" && exit 1 ;; \
    esac \
 && curl -fsSL "https://github.com/duckdb/duckdb/releases/download/${DUCKDB_VERSION}/duckdb_cli-linux-${DUCKDB_ARCH}.gz" -o /tmp/duckdb.gz \
 && echo "${DUCKDB_SHA256}  /tmp/duckdb.gz" | sha256sum -c - \
 && gunzip /tmp/duckdb.gz \
 && mv /tmp/duckdb "$HOME/.local/bin/duckdb" \
 && chmod +x "$HOME/.local/bin/duckdb" \
 && "$HOME/.local/bin/duckdb" --version

# mcp-proxy — stdio↔SSE/Streamable-HTTP bridge so any agent CLI can talk to remote MCP servers.
ARG MCP_PROXY_VERSION=v0.12.0
RUN PATH="$HOME/.local/bin:$PATH" uv tool install "mcp-proxy==${MCP_PROXY_VERSION#v}" \
 && PATH="$HOME/.local/bin:$PATH" mcp-proxy --version

# spec-kit — GitHub's spec-driven development toolkit (specify CLI).
# Installed from git so agents can run `specify init` and use /speckit.* workflows.
ARG SPEC_KIT_REF=main
RUN PATH="$HOME/.local/bin:$PATH" uv tool install "git+https://github.com/github/spec-kit.git@${SPEC_KIT_REF}" \
 && PATH="$HOME/.local/bin:$PATH" specify --version

RUN mkdir -p /home/${USERNAME}/.ssh \
 && chmod 700 /home/${USERNAME}/.ssh \
 && printf '[user]\n\tname = %s\n\temail = %s\n[init]\n\tdefaultBranch = main\n' \
    "${GIT_USER_NAME}" "${GIT_USER_EMAIL}" > /home/${USERNAME}/.gitconfig

WORKDIR /workspaces

ENV PATH="/home/${USERNAME}/.local/go/bin:${PNPM_HOME}:/home/${USERNAME}/.local/node-active:/home/${USERNAME}/.local/bin:/app:${PATH}"
ENV DOCKER_HOST="unix:///tmp/podman.sock"
ENV TESTCONTAINERS_HOST_OVERRIDE="localhost"
ENV TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE="/tmp/podman.sock"
ENV TESTCONTAINERS_RYUK_DISABLED="true"
ENV AARDVARK_BINARY="/usr/bin/aardvark-dns"

COPY --chown=${USER_UID}:${USER_GID} docker/entrypoint-podman.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["/app/multica", "daemon", "start", "--foreground"]

# ---------------------------------------------------------------------------
# claude — Claude Code CLI
# ---------------------------------------------------------------------------
FROM ${AGENT_BASE_IMAGE} AS claude

ARG USERNAME=agent

RUN curl -fsSL https://claude.ai/install.sh | bash
ENV MULTICA_CLAUDE_PATH=/home/${USERNAME}/.local/bin/claude

# ---------------------------------------------------------------------------
# cursor — Cursor CLI
# ---------------------------------------------------------------------------
FROM ${AGENT_BASE_IMAGE} AS cursor

ARG USERNAME=agent

RUN curl https://cursor.com/install -fsS | bash
ENV MULTICA_CURSOR_PATH=/home/${USERNAME}/.local/bin/cursor-agent

# ---------------------------------------------------------------------------
# opencode — OpenCode CLI
# ---------------------------------------------------------------------------
FROM ${AGENT_BASE_IMAGE} AS opencode

ARG USERNAME=agent

RUN curl -fsSL https://opencode.ai/install | bash
ENV MULTICA_OPENCODE_PATH=/home/${USERNAME}/.opencode/bin/opencode

RUN mkdir -p /home/${USERNAME}/.config/opencode /home/${USERNAME}/.local/share/opencode

# ---------------------------------------------------------------------------
# codex — OpenAI Codex CLI (npm @openai/codex; binary lands in the nvm bin dir)
# ---------------------------------------------------------------------------
FROM ${AGENT_BASE_IMAGE} AS codex

ARG USERNAME=agent

RUN npm install -g @openai/codex
ENV MULTICA_CODEX_PATH=/home/${USERNAME}/.local/node-active/codex

# ---------------------------------------------------------------------------
# kimi — Kimi Code CLI
# ---------------------------------------------------------------------------
FROM ${AGENT_BASE_IMAGE} AS kimi

ARG USERNAME=agent

RUN curl -fsSL https://code.kimi.com/kimi-code/install.sh | KIMI_INSTALL_DIR=/home/${USERNAME}/.local KIMI_NO_MODIFY_PATH=1 bash
ENV MULTICA_KIMI_PATH=/home/${USERNAME}/.local/bin/kimi

# ---------------------------------------------------------------------------
# agy — Antigravity CLI
# ---------------------------------------------------------------------------
FROM ${AGENT_BASE_IMAGE} AS agy

ARG USERNAME=agent

RUN curl -fsSL https://antigravity.google/cli/install.sh | bash
ENV MULTICA_ANTIGRAVITY_PATH=/home/${USERNAME}/.local/bin/agy
