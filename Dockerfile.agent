# Multica agent images: shared base + per-CLI targets.
#
#   make build-all
#   make build-claude IMAGE=ghcr.io/org/multica-agent TAG=v1.0.0
#
# Or: docker build -f Dockerfile.agent --target <claude|cursor|opencode|codex|gemini|agy> -t <image> .

ARG MULTICA_IMAGE=ghcr.io/multica-ai/multica-backend
ARG MULTICA_TAG=latest
FROM ${MULTICA_IMAGE}:${MULTICA_TAG} AS multica

# ---------------------------------------------------------------------------
# base — multica CLI, Podman, nvm, pnpm, entrypoint (no agent CLI)
# ---------------------------------------------------------------------------
FROM debian:stable-slim AS base

# nvm requires bash; default /bin/sh is dash (https://github.com/nvm-sh/nvm#installing-in-docker)
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

WORKDIR /app

COPY --from=multica /app/multica /app/multica

ARG USER_UID=1000
ARG USER_GID=1000
ARG USERNAME=agent
ARG GIT_USER_NAME=Multica Agent
ARG GIT_USER_EMAIL=agent@example.com

RUN groupadd --gid ${USER_GID} ${USERNAME} \
 && useradd --uid ${USER_UID} --gid ${USER_GID} --create-home --shell /bin/bash ${USERNAME}

RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates \
      tzdata \
      bash \
      curl \
      git \
      openssh-client \
      jq ripgrep \
      python3 \
      podman \
      passt \
      aardvark-dns \
      netavark \
      fuse-overlayfs \
      slirp4netns \
      uidmap \
  && rm -rf /var/lib/apt/lists/* \
  && touch /etc/subuid /etc/subgid \
  && sed -i "/^${USERNAME}:/d" /etc/subuid 2>/dev/null || true \
  && sed -i "/^${USERNAME}:/d" /etc/subgid 2>/dev/null || true \
  && echo "${USERNAME}:100000:65536" >> /etc/subuid \
  && echo "${USERNAME}:100000:65536" >> /etc/subgid \
  && ln -sf /usr/bin/podman /usr/local/bin/docker \
  && mkdir -p /home/${USERNAME}/.config/containers \
  && printf '[network]\nfirewall_driver = "none"\nnetwork_cmd_path = "/usr/bin/pasta"\n\n[engine]\nhelper_binaries_dir = ["/usr/libexec/podman", "/usr/lib/podman", "/usr/bin", "/home/%s/.local/bin"]\n' "${USERNAME}" > /home/${USERNAME}/.config/containers/containers.conf \
  && chown -R ${USER_UID}:${USER_GID} /home/${USERNAME}/.config

RUN mkdir -p /workspaces && chown ${USER_UID}:${USER_GID} /workspaces

USER ${USERNAME}
ARG NVM_VERSION=master
ARG NODE_VERSION=node
ENV NVM_DIR=/home/${USERNAME}/.nvm
ENV BASH_ENV=/home/${USERNAME}/.bash_env
RUN touch "${BASH_ENV}" \
 && echo '. "${NVM_DIR}/nvm.sh"' >> "${BASH_ENV}" \
 && echo '. "${BASH_ENV}"' >> ~/.bashrc
RUN if [ "${NVM_VERSION}" = "master" ]; then \
      install_url="https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh"; \
    else \
      install_url="https://raw.githubusercontent.com/nvm-sh/nvm/v${NVM_VERSION#v}/install.sh"; \
    fi; \
    curl -o- "${install_url}" | PROFILE="${BASH_ENV}" bash
RUN . "${NVM_DIR}/nvm.sh" \
 && nvm install "${NODE_VERSION}" \
 && nvm alias default "${NODE_VERSION}" \
 && NODE_BIN_DIR="$(dirname "$(nvm which default)")" \
 && echo "export PATH=\"${NODE_BIN_DIR}:\${PATH}\"" >> "${BASH_ENV}" \
 && mkdir -p "${HOME}/.local" \
 && ln -sfn "${NODE_BIN_DIR}" "${HOME}/.local/node-active"
RUN curl -fsSL https://get.pnpm.io/install.sh | ENV="$HOME/.bashrc" SHELL="$(which bash)" bash -

ARG GO_VERSION=1.26.4
RUN GO_ARCH="$(uname -m)" \
 && case "${GO_ARCH}" in \
      x86_64)  GO_ARCH="amd64" ;; \
      aarch64) GO_ARCH="arm64" ;; \
      *) echo "Unsupported architecture: ${GO_ARCH}" && exit 1 ;; \
    esac \
 && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${GO_ARCH}.tar.gz" -o /tmp/go.tar.gz \
 && mkdir -p "${HOME}/.local/go" \
 && tar -C "${HOME}/.local/go" --strip-components=1 -xzf /tmp/go.tar.gz \
 && rm /tmp/go.tar.gz \
 && "${HOME}/.local/go/bin/go" version

ARG RTK_VERSION=v0.42.3
ARG RTK_INSTALL_SHA256=ab22d109f920db7d931ef6aa97d9460d93f41d296981db8446afed96ea9661e5
RUN curl -fsSL "https://raw.githubusercontent.com/rtk-ai/rtk/refs/tags/${RTK_VERSION}/install.sh" -o /tmp/rtk-install.sh \
 && echo "${RTK_INSTALL_SHA256}  /tmp/rtk-install.sh" | sha256sum -c - \
 && RTK_VERSION="${RTK_VERSION}" sh /tmp/rtk-install.sh \
 && rm /tmp/rtk-install.sh

ENV PNPM_HOME=/home/${USERNAME}/.local/share/pnpm

RUN mkdir -p /home/${USERNAME}/.ssh \
 && chmod 700 /home/${USERNAME}/.ssh \
 && printf '[user]\n\tname = %s\n\temail = %s\n[init]\n\tdefaultBranch = main\n' \
    "${GIT_USER_NAME}" "${GIT_USER_EMAIL}" > /home/${USERNAME}/.gitconfig

WORKDIR /workspaces

ENV PATH="/home/${USERNAME}/.local/go/bin:${PNPM_HOME}:/home/${USERNAME}/.local/node-active:/home/${USERNAME}/.local/bin:/app:${PATH}"
ENV DOCKER_HOST="unix:///tmp/podman.sock"
ENV TESTCONTAINERS_HOST_OVERRIDE="localhost"
ENV TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE="/tmp/podman.sock"
ENV TESTCONTAINERS_RYUK_DISABLED="true"
ENV AARDVARK_BINARY="/usr/bin/aardvark-dns"

COPY --chown=${USER_UID}:${USER_GID} docker/entrypoint-podman.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["/app/multica", "daemon", "start", "--foreground"]

# ---------------------------------------------------------------------------
# claude — Claude Code CLI
# ---------------------------------------------------------------------------
FROM base AS claude

ARG USERNAME=agent

RUN curl -fsSL https://claude.ai/install.sh | bash
ENV MULTICA_CLAUDE_PATH=/home/${USERNAME}/.local/bin/claude

# ---------------------------------------------------------------------------
# cursor — Cursor CLI
# ---------------------------------------------------------------------------
FROM base AS cursor

ARG USERNAME=agent

RUN curl https://cursor.com/install -fsS | bash
ENV MULTICA_CURSOR_PATH=/home/${USERNAME}/.local/bin/cursor-agent

# ---------------------------------------------------------------------------
# opencode — OpenCode CLI
# ---------------------------------------------------------------------------
FROM base AS opencode

ARG USERNAME=agent

RUN curl -fsSL https://opencode.ai/install | bash
ENV MULTICA_OPENCODE_PATH=/home/${USERNAME}/.opencode/bin/opencode

RUN mkdir -p /home/${USERNAME}/.config/opencode /home/${USERNAME}/.local/share/opencode

# ---------------------------------------------------------------------------
# codex — OpenAI Codex CLI (npm @openai/codex; binary lands in the nvm bin dir)
# ---------------------------------------------------------------------------
FROM base AS codex

ARG USERNAME=agent

RUN npm install -g @openai/codex
ENV MULTICA_CODEX_PATH=/home/${USERNAME}/.local/node-active/codex

# ---------------------------------------------------------------------------
# gemini — Google Gemini CLI (npm @google/gemini-cli)
# ---------------------------------------------------------------------------
FROM base AS gemini

ARG USERNAME=agent

RUN npm install -g @google/gemini-cli
ENV MULTICA_GEMINI_PATH=/home/${USERNAME}/.local/node-active/gemini

# ---------------------------------------------------------------------------
# agy — Antigravity CLI
# ---------------------------------------------------------------------------
FROM base AS agy

ARG USERNAME=agent

RUN curl -fsSL https://antigravity.google/cli/install.sh | bash
ENV MULTICA_ANTIGRAVITY_PATH=/home/${USERNAME}/.local/bin/agy
